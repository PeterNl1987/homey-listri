            "title": {
                "en": "Task",
                "nl": "Taak"
            }
        },
        {
            "type": "number",
            "name": "days",
            "min": 0,
            "title": {
                "en": "Days",
                "nl": "Dagen"
            }
        },
        {
            "type": "time",
            "name": "time",
            "title": {
